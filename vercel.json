{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/main"
    },
    {
      "source": "/signup/reseller",
      "destination": "/signup-reseller.html"
    },
    {
      "source": "/signup/resseler",
      "destination": "/signup-reseller.html"
    },
    {
      "source": "/signupressler",
      "destination": "/signup-reseller.html"
    }
  ]
}
