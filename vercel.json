{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "api/main.py"
    },
    {
      "source": "/signup/reseller",
      "destination": "/signup-reseller.html"
    }
  ]
}
