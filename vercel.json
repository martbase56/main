{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/main"
    },
    {
      "source": "/signup/reseller",
      "destination": "/public/signup/reseller.html"
    },
    {
      "source": "/dashboard/category/:slug",
      "destination": "/public/dashboard/reseller-category.html?slug=:slug"
    },
    {
      "source": "/admin/:page",
      "destination": "/public/admin/:page.html"
    },
    {
      "source": "/dashboard/:page",
      "destination": "/public/dashboard/:page.html"
    },
    {
      "source": "/:page",
      "destination": "/public/:page.html"
    },
    {
      "source": "/",
      "destination": "/public/index.html"
    }
  ]
}
